# Website protection. Set these when this app is on the internet.
APP_USERNAME=keystone
APP_PASSWORD=change-this-password

# Hosting database location. On a server, point this at a persistent disk/volume.
DB_PATH=/data/tasks.sqlite

# REQUIRED on Vercel: the serverless filesystem is temporary, so data only
# persists in a Turso database. Create one at https://turso.tech and set both
# of these in the Vercel project's environment variables.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional Ring Tommy / done notifications.
TASK_NOTIFY_EMAIL=tommy@keystone.studio
TASK_NOTIFY_PHONE=+18456633682

RESEND_API_KEY=
TASK_NOTIFY_FROM=Keystone Tasks <tasks@keystone.studio>

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

TASK_DONE_WEBHOOK_URL=
